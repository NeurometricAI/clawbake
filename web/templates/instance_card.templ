package templates

import v1alpha1 "github.com/clawbake/clawbake/api/v1alpha1"

templ InstanceCreated(instance v1alpha1.ClawInstance, tuiEnabled bool, shellEnabled bool, currentUserID string) {
	<div id="instance-list" hx-swap-oob="innerHTML">
		@InstanceCard(instance, nil, tuiEnabled, shellEnabled, currentUserID)
	</div>
	<span id="new-instance-btn" hx-swap-oob="innerHTML"></span>
}

templ StatusBadge(instance v1alpha1.ClawInstance) {
	<span
		id={ "status-" + instance.Name }
		class={ "badge badge-" + statusClass(instance.Status.Phase) }
		if !isTerminalPhase(instance.Status.Phase) {
			hx-get={ "/ui/instances/" + instance.Name + "/status" }
			hx-swap="outerHTML"
			hx-trigger="every 5s"
		}
	>{ displayPhase(instance.Status.Phase) }</span>
}

templ InstanceLinks(instance v1alpha1.ClawInstance, tuiEnabled bool, shellEnabled bool, isOwner bool) {
	<div id={ "links-" + instance.Name }>
		if instance.Status.Phase == "Running" && isOwner {
			<p>
				<a href="/proxy/web/" target="_blank">Web UI</a>
				if tuiEnabled {
					&nbsp;|&nbsp;
					<a href="/proxy/tui/" target="_blank">Text UI</a>
				}
				if shellEnabled {
					&nbsp;|&nbsp;
					<a href="/proxy/shell/" target="_blank">Shell</a>
				}
			</p>
		}
	</div>
}

templ InstanceLinksDetail(instance v1alpha1.ClawInstance, tuiEnabled bool, shellEnabled bool, isOwner bool) {
	<div id={ "links-" + instance.Name }>
		if instance.Status.Phase == "Running" && isOwner {
			if tuiEnabled || shellEnabled {
				<div class="grid">
					<a href="/proxy/web/" target="_blank" role="button">
						Open Web UI
					</a>
					if tuiEnabled {
						<a href="/proxy/tui/" target="_blank" role="button" class="secondary">
							Open Text UI
						</a>
					}
					if shellEnabled {
						<a href="/proxy/shell/" target="_blank" role="button" class="secondary">
							Open Shell
						</a>
					}
				</div>
			} else {
				<p>
					<a href="/proxy/web/" target="_blank" role="button">
						Open Web UI
					</a>
				</p>
			}
		}
	</div>
}

templ StatusPollResponse(instance v1alpha1.ClawInstance, tuiEnabled bool, shellEnabled bool, isOwner bool, detail bool) {
	@StatusBadge(instance)
	if instance.Status.Phase == "Running" && isOwner {
		if detail {
			@instanceLinksDetailOOB(instance, tuiEnabled, shellEnabled)
		} else {
			@instanceLinksOOB(instance, tuiEnabled, shellEnabled)
		}
	}
}

templ instanceLinksOOB(instance v1alpha1.ClawInstance, tuiEnabled bool, shellEnabled bool) {
	<div id={ "links-" + instance.Name } hx-swap-oob="true">
		<p>
			<a href="/proxy/web/" target="_blank">Web UI</a>
			if tuiEnabled {
				&nbsp;|&nbsp;
				<a href="/proxy/tui/" target="_blank">Text UI</a>
			}
			if shellEnabled {
				&nbsp;|&nbsp;
				<a href="/proxy/shell/" target="_blank">Shell</a>
			}
		</p>
	</div>
}

templ instanceLinksDetailOOB(instance v1alpha1.ClawInstance, tuiEnabled bool, shellEnabled bool) {
	<div id={ "links-" + instance.Name } hx-swap-oob="true">
		if tuiEnabled || shellEnabled {
			<div class="grid">
				<a href="/proxy/web/" target="_blank" role="button">
					Open Web UI
				</a>
				if tuiEnabled {
					<a href="/proxy/tui/" target="_blank" role="button" class="secondary">
						Open Text UI
					</a>
				}
				if shellEnabled {
					<a href="/proxy/shell/" target="_blank" role="button" class="secondary">
						Open Shell
					</a>
				}
			</div>
		} else {
			<p>
				<a href="/proxy/web/" target="_blank" role="button">
					Open Web UI
				</a>
			</p>
		}
	</div>
}

templ InstanceCard(instance v1alpha1.ClawInstance, userNames map[string]string, tuiEnabled bool, shellEnabled bool, currentUserID string) {
	<article id={ "instance-" + instance.Name }>
		<header>
			<div class="instance-header">
				<h3><a href={ templ.SafeURL("/ui/instances/" + instance.Name) }>Instance</a></h3>
				@StatusBadge(instance)
			</div>
		</header>
		if name, ok := userNames[instance.Spec.UserId]; ok {
			<p><strong>Owner:</strong> { name }</p>
		}
		<p><strong>Image:</strong> { instance.Spec.Image }</p>
		@InstanceLinks(instance, tuiEnabled, shellEnabled, instance.Spec.UserId == currentUserID)
		<footer>
			<a href={ templ.SafeURL("/ui/instances/" + instance.Name) } role="button" class="outline">Details</a>
			<button
				class="secondary outline"
				hx-delete={ "/ui/instances/" + instance.Name }
				hx-confirm="Delete this instance?"
				hx-target={ "#instance-" + instance.Name }
				hx-swap="outerHTML"
			>Delete</button>
		</footer>
	</article>
}
