DATABASE_URL=postgresql://postgres:postgres@db:5432/clawbake?sslmode=disable

# Server port (8081 avoids collision with k3d ingress on host:8080)
PORT=8081

# OIDC Configuration (Google)
# Leave empty to use dev login screen with role selection
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=

# Session
SESSION_SECRET=dev-session-secret

# Slack Bot
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Kubernetes
KUBE_NAMESPACE=clawbake

# Ingress: nip.io provides wildcard DNS resolving to 127.0.0.1
# k3d maps host:8080 -> cluster ingress, so INGRESS_PORT=8080
# Override in .env or .env.local for production values
INGRESS_DOMAIN=claw.127-0-0-1.nip.io
INGRESS_SCHEME=http
INGRESS_PORT=8080
