DATABASE_URL=postgresql://clawbake:clawbake@host.docker.internal:5432/clawbake?sslmode=disable

# Server port (8081 avoids collision with k3d ingress on host:8080)
PORT=8081

# Public URL of the clawbake web app (used in Slack bot links, etc.)
BASE_URL=http://clawbake.127-0-0-1.nip.io:8080

# OIDC Configuration (Google)
# Leave empty to use dev login screen with role selection
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=

# Session
SESSION_SECRET=dev-session-secret

# Slack Bot
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Kubernetes
KUBE_NAMESPACE=clawbake
